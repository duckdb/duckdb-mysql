# SECTION 15: Multi-table Plan Cache Independence

statement ok
DROP TABLE IF EXISTS s1.bench_aux;

statement ok
CREATE TABLE s1.bench_aux(
    id INTEGER PRIMARY KEY,
    val INTEGER
)

statement ok
INSERT INTO s1.bench_aux SELECT range, range % 50 FROM range(5000)

statement ok
CREATE INDEX idx_bench_aux_val ON s1.bench_aux(val)

statement ok
CALL mysql_execute('s1', 'ANALYZE TABLE bench_aux')

statement ok
CALL mysql_clear_cache()

# Query both tables
query II
SELECT id, category FROM s1.bench_main WHERE category = 1 LIMIT 1
----
1	1

query II
SELECT id, val FROM s1.bench_aux WHERE val = 1 LIMIT 1
----
1	1

# Both should have independent cache entries
query I
SELECT COUNT(*) FROM mysql_debug_execution_plan()
WHERE table_name IN ('bench_main', 'bench_aux')
