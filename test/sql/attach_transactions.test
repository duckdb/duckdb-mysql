# name: test/sql/attach_transactions.test
# description: Test ATTACH and transaction semantics (BEGIN, COMMIT, ROLLBACK, etc)
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
DROP TABLE IF EXISTS s.test_tran

# roll back create table
statement ok
BEGIN

statement ok
CREATE TABLE s.test_tran(i INTEGER);

statement ok
ROLLBACK

# DDL statements are not transactional in MySQL so rolling back does nothing
statement ok
SELECT * FROM s.test_tran

# roll back insert
statement ok
BEGIN

statement ok
INSERT INTO s.test_tran VALUES (42)

query I
SELECT * FROM s.test_tran
----
42

statement ok
ROLLBACK

query I
SELECT * FROM s.test_tran
----

# commit insert
statement ok
BEGIN

statement ok
INSERT INTO s.test_tran VALUES (1), (2), (3)

statement ok
COMMIT

query I
SELECT * FROM s.test_tran
----
1
2
3

# rollback delete
statement ok
BEGIN

statement ok
DELETE FROM s.test_tran WHERE i=2

query I
SELECT * FROM s.test_tran
----
1
3

statement ok
ROLLBACK

query I
SELECT * FROM s.test_tran
----
1
2
3

# rollback update
statement ok
BEGIN

statement ok
UPDATE s.test_tran SET i=i+100

query I
SELECT * FROM s.test_tran
----
101
102
103

statement ok
ROLLBACK

query I
SELECT * FROM s.test_tran
----
1
2
3

# rollback large delete
statement ok
BEGIN

statement ok
INSERT INTO s.test_tran SELECT 2 FROM range(10000);

statement ok
DELETE FROM s.test_tran WHERE i=2

query I
SELECT * FROM s.test_tran
----
1
3

statement ok
ROLLBACK

query I
SELECT * FROM s.test_tran
----
1
2
3

# FIXME - alter table
mode skip

# rollback alter table
statement ok
BEGIN

statement ok
ALTER TABLE s.test_tran ADD COLUMN b INTEGER

query II
SELECT * FROM s.test_tran
----
1	NULL
2	NULL
3	NULL

statement ok
UPDATE s.test_tran SET b=i+100 WHERE i!=2

query II
SELECT * FROM s.test_tran
----
1	101
2	NULL
3	103

statement ok
ROLLBACK

query I
SELECT * FROM s.test_tran
----
1
2
3

# Cleanup
statement ok
DROP TABLE IF EXISTS s.test_tran

statement ok
DETACH s

